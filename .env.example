# ==========================
# Memento AI Environment Configuration
# ==========================

# Backend
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///memento.db

# AI Runtime
MODEL_PROVIDER=ollama
MODEL_NAME=qwen2.5:3b
OLLAMA_HOST=http://localhost:11434

# llama.cpp (optional)
MODEL_PATH=models/qwen2.5-3b.gguf

# Features
ENABLE_STREAMING=true
ENABLE_RAG=true
ENABLE_MEMORY=true
ENABLE_OCR=true
ENABLE_AUDIO=true
ENABLE_VIDEO=true

# Application
DEFAULT_LANGUAGE=en
LOG_LEVEL=INFO
